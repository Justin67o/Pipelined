// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}



model User {
  id             String        @id @default(cuid())
  email          String        @unique
  password       String
  name           String
  resumeText     String?
  activeCycleId  String?
  activeCycle    CoopCycle?    @relation("ActiveCycle", fields: [activeCycleId], references: [id])
  cycles         CoopCycle[]   @relation("UserCycles")
  applications   Application[]
  createdAt      DateTime      @default(now())
}

model CoopCycle {
  id           String        @id @default(cuid())
  userId       String
  user         User          @relation("UserCycles", fields: [userId], references: [id])
  term         String
  year         Int
  applications Application[]
  activeFor    User[]        @relation("ActiveCycle")
  createdAt    DateTime      @default(now())

  @@unique([userId, term, year])
}

model Application {
  id             String     @id @default(cuid())
  userId         String
  user           User       @relation(fields: [userId], references: [id])
  cycleId        String?
  cycle          CoopCycle? @relation(fields: [cycleId], references: [id])
  company        String
  role           String
  jobUrl         String?
  status         Status     @default(SAVED)
  matchScore     Int?
  matchedSkills  String[]
  missingSkills  String[]
  salary         String?
  location       String?
  remote         Boolean    @default(false)
  dateApplied    DateTime?
  deadline       DateTime?
  followUpDate   DateTime?
  reminderSent   Boolean    @default(false)
  jobDescription String?
  notes          String?
  activities     Activity[]
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
}

model Activity {
  id            String       @id @default(cuid())
  applicationId String
  application   Application  @relation(fields: [applicationId], references: [id])
  type          ActivityType
  description   String
  createdAt     DateTime     @default(now())
}

enum Status {
  SAVED
  APPLIED
  PHONE_SCREEN
  INTERVIEW
  OFFER
  REJECTED
}

enum ActivityType {
  STATUS_CHANGE
  NOTE_ADDED
  REMINDER_SET
}
